# Environment Configuration Template
# Copy this file to .env and update values for your environment

# ====================
# API Configuration
# ====================
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
API_RELOAD=true

# ====================
# Model Configuration
# ====================
MODEL_PATH=models/production/model.pkl
MODEL_THRESHOLD=0.5
MODEL_VERSION=v1.0

# ====================
# Data Configuration
# ====================
DATA_PATH=data/
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
FEATURES_PATH=data/features/

# ====================
# Database Configuration
# ====================
DATABASE_TYPE=postgresql
DATABASE_URL=postgresql://user:password@localhost:5432/supply_chain
DATABASE_ECHO=false

# ====================
# MLflow Configuration
# ====================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=supply_chain_experiments
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=./mlruns

# ====================
# Logging Configuration
# ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ====================
# Security Configuration
# ====================
SECRET_KEY=change-me-in-production-use-strong-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
API_KEY=your-api-key-here

# ====================
# Redis Configuration (Optional)
# ====================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ====================
# CORS Configuration
# ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000

# ====================
# Deployment Configuration
# ====================
ENVIRONMENT=development
DEBUG=true

# ====================
# Email Configuration (Optional)
# ====================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ====================
# Feature Flags
# ====================
ENABLE_SHAP_EXPLANATIONS=true
ENABLE_BATCH_PREDICTIONS=true
ENABLE_MONITORING=true
ENABLE_LOGGING=true
