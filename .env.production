# ==============================================================================
# SmartShip AI - Production Environment Configuration
# 
# CRITICAL: Change all default passwords and credentials before deployment!
# Store sensitive values securely using AWS Secrets Manager, Azure Key Vault,
# Google Cloud Secret Manager, or HashiCorp Vault in production.
# ==============================================================================

# ==============================================================================
# API Configuration
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1
API_RELOAD=false
API_WORKERS=4
API_TIMEOUT=60
API_MAX_REQUESTS=1000

# ==============================================================================
# Security Configuration
# CRITICAL: Update these values!
# ==============================================================================
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_change_me_in_production

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,https://yourdomain.com

# Admin API key for privileged operations
ADMIN_API_KEY=your_admin_key_here_change_me

# ==============================================================================
# Model Configuration
# ==============================================================================
MODEL_PATH=artifacts/full_pipeline.pkl
MODEL_THRESHOLD=0.5
MODEL_VERSION=v1.0.0
MODEL_CONFIDENCE_THRESHOLD=0.6
MODEL_BATCH_SIZE=32

# ==============================================================================
# Frontend Configuration
# ==============================================================================
# Frontend will use this URL to connect to API
API_URL=http://localhost:8000
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_LOGGER_LEVEL=info

# ==============================================================================
# Database Configuration
# CRITICAL: Use strong passwords in production!
# ==============================================================================
DATABASE_TYPE=postgresql
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://supply_chain_user:secure_password_change_me@postgres:5432/supply_chain
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_POOL_RECYCLE=3600
DATABASE_POOL_PRE_PING=true

# ==============================================================================
# Cache Configuration (Redis)
# ==============================================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
CACHE_TTL=3600
CACHE_ENABLED=true

# ==============================================================================
# Data Configuration
# ==============================================================================
DATA_PATH=data/
RAW_DATA_PATH=data/raw/
PROCESSED_DATA_PATH=data/processed/
FEATURES_PATH=data/features/
SAMPLE_SIZE=10000

# ==============================================================================
# MLflow Configuration
# ==============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=supply_chain_experiments
MLFLOW_BACKEND_STORE_URI=sqlite:///mlflow.db
MLFLOW_DEFAULT_ARTIFACT_ROOT=./mlruns
MLFLOW_ENABLED=true

# ==============================================================================
# Logging Configuration
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# ==============================================================================
# Feature Engineering Configuration
# ==============================================================================
FEATURE_ENGINEERING_ENABLED=true
FEATURE_SCALING_METHOD=standard
FEATURE_SELECTION_METHOD=importance
NUM_TOP_FEATURES=20

# ==============================================================================
# Model Training Configuration
# ==============================================================================
RANDOM_SEED=42
TRAIN_TEST_SPLIT=0.2
VALIDATION_SPLIT=0.2
CROSS_VALIDATION_FOLDS=5
EARLY_STOPPING_PATIENCE=10
EARLY_STOPPING_ROUNDS=10

# ==============================================================================
# XGBoost Configuration
# ==============================================================================
XGBOOST_LEARNING_RATE=0.1
XGBOOST_MAX_DEPTH=5
XGBOOST_N_ESTIMATORS=100
XGBOOST_SUBSAMPLE=0.8
XGBOOST_COLSAMPLE_BYTREE=0.8
XGBOOST_REG_LAMBDA=1.0
XGBOOST_REG_ALPHA=0.0
XGBOOST_OBJECTIVE=binary:logistic
XGBOOST_EVAL_METRIC=auc

# ==============================================================================
# Explainability Configuration
# ==============================================================================
EXPLAINABILITY_ENABLED=true
SHAP_ENABLED=true
SHAP_BACKGROUND_SAMPLES=100
LIME_ENABLED=false
FEATURE_IMPORTANCE_TOP_N=10

# ==============================================================================
# Generative AI Configuration (Optional)
# ==============================================================================
# Set to "gemini" or "openai" or "anthropic"
GENAI_PROVIDER=gemini

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

GENAI_ENABLED=true
GENAI_MODEL=gemini-pro
GENAI_TEMPERATURE=0.7
GENAI_MAX_TOKENS=500

# ==============================================================================
# Monitoring & Alerts Configuration
# ==============================================================================
MONITORING_ENABLED=true
METRICS_COLLECTION_INTERVAL=60  # seconds
ALERT_EMAIL=admin@yourdomain.com
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==============================================================================
# Performance Configuration
# ==============================================================================
ENABLE_CACHING=true
CACHE_PREDICTIONS=true
CACHE_FEATURES=true
PREDICTION_TIMEOUT=10  # seconds
BATCH_PREDICTION_MAX_SIZE=1000

# ==============================================================================
# Data Quality Configuration
# ==============================================================================
DATA_QUALITY_CHECKS_ENABLED=true
DRIFT_DETECTION_ENABLED=true
DRIFT_THRESHOLD=0.1
MISSING_VALUE_THRESHOLD=0.3

# ==============================================================================
# Deployment Environment
# ==============================================================================
ENVIRONMENT=production
DEBUG=false
TESTING=false

# ==============================================================================
# Container/Orchestration Configuration (Docker/Kubernetes)
# ==============================================================================
CONTAINER_NAME=smartship-api
DOCKER_REGISTRY=your-registry.azurecr.io
DOCKER_IMAGE_TAG=latest
KUBERNETES_NAMESPACE=smartship
KUBERNETES_REPLICAS=3

# ==============================================================================
# Backup Configuration
# ==============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily  # daily, weekly, monthly
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=s3://your-bucket/backups

# ==============================================================================
# Email Configuration (for notifications)
# ==============================================================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=smartship-alerts@yourdomain.com
SMTP_ENABLED=false

# ==============================================================================
# AWS Configuration (if using AWS for storage/services)
# ==============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=smartship-ai-bucket
AWS_ENABLED=false

# ==============================================================================
# GCP Configuration (if using Google Cloud)
# ==============================================================================
GCP_PROJECT_ID=your-project-id
GCP_CREDENTIALS_PATH=/app/credentials/gcp-key.json
GCP_STORAGE_BUCKET=smartship-ai-bucket
GCP_ENABLED=false

# ==============================================================================
# Azure Configuration (if using Azure)
# ==============================================================================
AZURE_STORAGE_ACCOUNT_NAME=smartshipai
AZURE_STORAGE_ACCOUNT_KEY=your_storage_key
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=smartship-ai
AZURE_ENABLED=false

# ==============================================================================
# Rate Limiting Configuration
# ==============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100  # requests per window
RATE_LIMIT_WINDOW=60  # seconds
RATE_LIMIT_BURST=150

# ==============================================================================
# Feature Flag Configuration
# ==============================================================================
FEATURE_NEW_PREDICTION_ENGINE=false
FEATURE_ADVANCED_EXPLANATIONS=true
FEATURE_BATCH_PROCESSING=true
FEATURE_REAL_TIME_UPDATES=true

# ==============================================================================
# Advanced Configuration (Optional)
# ==============================================================================
# Distributed tracing
JAEGER_ENABLED=false
JAEGER_HOST=localhost
JAEGER_PORT=6831

# Custom metric server
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Custom webhooks for events
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-endpoint.com/webhook

# ==============================================================================
# Legacy/Compatibility Configuration
# ==============================================================================
LEGACY_MODEL_SUPPORT=false
ENABLE_V1_API=true
ENABLE_V2_API=false

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================
# Last Updated: May 15, 2026
# Next Review: August 15, 2026
